# ─── PondDB Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Run `pond check` to validate your configuration.

# ─── Core (REQUIRED) ──────────────────────────────────────────────────────
POND_API_KEY=changeme                      # Master API key for authentication
POND_JWT_SECRET=your-jwt-secret-here       # JWT signing secret (change before deploying!)
POND_WEBSITE_SESSION_SECRET=your-session-secret  # Dashboard cookie signing secret

# ─── Server ───────────────────────────────────────────────────────────────
POND_HOST=0.0.0.0                          # Bind address
POND_PORT=8432                             # Server port

# ─── Storage ──────────────────────────────────────────────────────────────
POND_DATA_ROOT=./data                      # Dataset upload directory
POND_SQLITE_PATH=./ponddb.db              # Metadata store (SQLite) path

# ─── Session Lifecycle ────────────────────────────────────────────────────
POND_IDLE_TIMEOUT=300                      # Session idle timeout (seconds)
POND_MAX_SESSION_AGE=86400                 # Max session age (seconds, default 24h)
POND_SESSION_MEMORY_LIMIT=2GB             # DuckDB per-session memory limit
POND_SESSION_THREADS=4                     # DuckDB threads per session

# ─── PondAPI Rate Limiting ────────────────────────────────────────────────
POND_PONDAPI_RATE_LIMIT=10                 # Max executions per window per tenant
POND_PONDAPI_RATE_WINDOW=60                # Rate limit window (seconds)

# ─── JWT Configuration ───────────────────────────────────────────────────
POND_JWT_EXPIRY_SECONDS=3600               # Access token TTL (default 1h)

# ─── Resource Limits ─────────────────────────────────────────────────────
POND_MAX_RESULT_MB=100                     # Max result size in MB

# ─── OAuth (optional — leave blank to disable) ──────────────────────────
# POND_GOOGLE_CLIENT_ID=
# POND_GOOGLE_CLIENT_SECRET=
# POND_GITHUB_CLIENT_ID=
# POND_GITHUB_CLIENT_SECRET=
# POND_OAUTH_SECRET=your-oauth-hmac-secret
# POND_OAUTH_REDIRECT_BASE=http://localhost:8432

# ─── SMTP (optional — for invite emails) ────────────────────────────────
# POND_SMTP_HOST=smtp.gmail.com
# POND_SMTP_PORT=587
# POND_SMTP_USER=
# POND_SMTP_PASSWORD=
# POND_SMTP_FROM=noreply@example.com
# POND_BASE_URL=http://localhost:8432       # Base URL for invite email links

# ─── Landing Page ────────────────────────────────────────────────────────
# POND_CONTACT_EMAIL=contact@example.com   # Email shown in "Request Invite" link

# ─── Logging ─────────────────────────────────────────────────────────────
POND_LOG_LEVEL=INFO
