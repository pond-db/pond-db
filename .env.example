# PondDB environment variables
# Copy this file to .env and fill in your values.

# Required: secret key for JWT token signing (change before deploying)
POND_JWT_SECRET=your-secret-here

# Server bind settings
POND_HOST=0.0.0.0
POND_PORT=8432

# Paths (point these at your volume mount in production)
POND_DATA_ROOT=./data
POND_SQLITE_PATH=./ponddb.db

# Session lifecycle (seconds)
POND_IDLE_TIMEOUT=300
POND_MAX_SESSION_AGE=86400

# Resource limits
POND_MAX_RESULT_MB=100
POND_SESSION_MEMORY_LIMIT=2GB

# Logging
POND_LOG_LEVEL=INFO
